<head></head><body><div class="th-status-wrapper"><div class="th-topbar"><div class="th-topbar-corner-br"></div><div class="th-topbar-left"><span class="th-topbar-title" title="点击折叠/展开"><i class="fa-solid fa-crown"></i> 此间天地 <i class="fa-solid fa-crown"></i></span><div class="th-topbar-actions"><button class="th-icon-btn th-btn-locations" title="地点总览"><i class="fa-solid fa-compass"></i></button> <button class="th-icon-btn th-btn-events" title="事件总览"><i class="fa-solid fa-flag"></i></button> <button class="th-icon-btn th-btn-dlcs" title="DLC补充"><i class="fa-solid fa-folder-plus"></i></button> <button class="th-icon-btn th-btn-stash" title="储藏间"><i class="fa-solid fa-treasure-chest"></i></button> <button class="th-icon-btn th-btn-review" title="变量审核"><svg class="th-ico th-ico-bell th-review-bell-svg" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.268 21a2 2 0 0 0 3.464 0"></path><path d="M3.262 15.326A1 1 0 0 0 4 17h16a1 1 0 0 0 .74-1.673C19.41 13.956 18 12.499 18 8A6 6 0 0 0 6 8c0 4.499-1.411 5.956-2.738 7.326"></path></svg><svg class="th-ico th-ico-check th-review-check-svg" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg><span class="th-review-badge" style="display:none">0</span></button> <button class="th-icon-btn th-btn-menu" title="菜单"><i class="fa-solid fa-bars"></i></button><div class="th-menu-popover" style="display:none"><div class="th-menu-group"><div class="th-menu-group-label">系统</div><button class="th-menu-item th-btn-edit"><i class="fa-solid fa-sliders"></i><span>编辑模式</span></button><button class="th-menu-item th-btn-refresh"><i class="fa-solid fa-rotate-right"></i><span>刷新</span></button></div><div class="th-menu-group"><div class="th-menu-group-label">工具</div><button class="th-menu-item th-btn-worldbook"><i class="fa-solid fa-book-open"></i><span>世界书识别</span></button></div><div class="th-menu-group"><div class="th-menu-group-label">设置</div><button class="th-menu-item th-btn-api-settings" disabled><i class="fa-solid fa-key"></i><span>API 设置</span><span class="th-menu-soon">即将推出</span></button><button class="th-menu-item th-btn-appearance" disabled><i class="fa-solid fa-palette"></i><span>外观设置</span><span class="th-menu-soon">即将推出</span></button></div></div></div></div><div class="th-topbar-right"><button class="th-npc-filter-btn th-btn-cols-switcher" data-cols="2" title="点击切换 NPC 网格列数（1/2/3）">2</button><div class="th-npc-filter-btns"><button class="th-npc-filter-btn active" data-filter="all">全部</button> <button class="th-npc-filter-btn th-btn-presence-switcher" title="点击切换在场/离场过滤">在场</button></div><div class="th-npc-search-wrap"><i class="fa-solid fa-search"></i> <input type="search" class="th-npc-search" placeholder="搜索姓名 / 身份" maxlength="20" autocomplete="off" spellcheck="false"> <button class="th-npc-search-clear" type="button" title="清空搜索" aria-label="清空" style="display:none"><i class="fa-solid fa-xmark"></i></button></div><span class="th-world-divider">·</span> <span class="th-world-date"></span> <span class="th-world-divider">·</span> <span class="th-world-time"></span> <span class="th-world-divider">·</span> <span class="th-world-weather"></span></div></div><div class="th-review-panel"><div class="th-review-panel-header"><span class="th-review-panel-title">变量审核 <span class="th-review-pending-count"></span></span><div class="th-review-panel-actions"><button class="th-icon-btn th-icon-btn-success th-review-approve-all" title="全部同意" type="button"><i class="fa-solid fa-check"></i></button> <button class="th-icon-btn th-icon-btn-warn th-review-reject-all" title="全部拒绝" type="button"><i class="fa-solid fa-xmark"></i></button> <button class="th-icon-btn th-icon-btn-danger th-review-clear-all" title="清除全部历史" type="button"><i class="fa-solid fa-trash-can"></i></button> <button class="th-mini-btn th-review-tab active" data-tab="review" type="button">审核</button> <button class="th-mini-btn th-review-tab" data-tab="snapshot" type="button">快照</button> <button class="th-icon-btn th-review-panel-close" title="关闭 (Esc)" type="button" aria-label="关闭审核面板"><i class="fa-solid fa-xmark"></i></button></div></div><div class="th-review-panel-body"><div class="th-review-source-filter" style="display:none"></div><div class="th-review-list"></div><div class="th-snapshot-list" style="display:none"></div><div class="th-review-empty">暂无待审核变量</div></div></div><div class="th-main-wrap"><div class="th-main"><div class="th-left"><div class="th-user-hero"><div class="th-avatar-section"><div class="th-avatar-upload" title="点击上传头像"><div class="th-avatar-ring"><div class="th-avatar-img-wrap"><img class="th-avatar-img" alt="头像" style="display:none"> <span class="th-avatar-placeholder"><i class="fa-solid fa-user-astronaut"></i></span></div></div></div><div class="th-avatar-btns" style="display:none"><button class="th-avatar-btn th-avatar-btn-upload"><i class="fa-solid fa-camera-retro"></i></button> <button class="th-avatar-btn th-avatar-btn-delete"><i class="fa-solid fa-trash"></i></button></div></div><div class="th-user-hero-info"><div class="th-user-name-row"><span class="th-user-name-display"></span> <button class="th-btn-attr-modal" title="属性详情"><i class="fa-solid fa-chart-pie"></i></button></div><div class="th-money-row"><span class="th-money-display"><span class="th-money-icon"><i class="fa-solid fa-gem"></i></span> <span class="th-money-text"></span></span></div><div class="th-location-text"></div><div class="th-mini-actions"></div></div></div><div class="th-pb-row"><button class="th-pb-btn th-pb-posture"><i class="fa-solid fa-child-reaching"></i><span>姿态动作</span></button> <button class="th-pb-btn th-pb-body"><i class="fa-solid fa-hand-holding-heart"></i><span>身体状态</span></button></div><div class="th-section"><div class="th-section-header"><span class="th-section-icon"><i class="fa-solid fa-wand-magic-sparkles"></i></span> <span class="th-section-label">当前状态</span> <span class="th-section-count"></span></div><div class="th-block-row th-status-blocks"></div></div><div class="th-section"><div class="th-section-header"><span class="th-section-icon"><i class="fa-solid fa-vest"></i></span> <span class="th-section-label">当前穿着</span></div><div class="th-block-row th-clothing-blocks"></div></div></div><div class="th-right"><div class="th-npc-grid"></div></div></div></div><div class="th-modal-overlay" style="display:none"><div class="th-modal"><div class="th-modal-header"><span class="th-modal-title"></span> <button class="th-modal-close"><i class="fa-solid fa-xmark"></i></button></div><div class="th-modal-body"></div></div></div><div class="th-modal-overlay-2" style="display:none"><div class="th-modal th-modal-2"><div class="th-modal-header"><span class="th-modal-title-2"></span> <button class="th-modal-close-2"><i class="fa-solid fa-xmark"></i></button></div><div class="th-modal-body-2"></div></div></div><div class="th-image-overlay" style="display:none"><div class="th-image-close"><i class="fa-solid fa-xmark"></i></div><img class="th-image-full" alt="大图"></div><input type="file" class="th-avatar-file-input" accept="image/*" style="display:none"></div></body>